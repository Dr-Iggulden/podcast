  "shortcuts": [
    {
      "name": "Latest Episode",
      "short_name": "Latest",
      "url": "/",
      "description": "Play the latest episode",
      "icons": [{ "src": "icon-96x96.png", "sizes": "96x96" }]
    },
    {
      "name": "My Notes",
      "short_name": "Notes",
      "url": "/notes",
      "description": "Open your episode notes",
      "icons": [{ "src": "icon-96x96.png", "sizes": "96x96" }]
    },
    {
      "name": "Metabolic Masters",
      "short_name": "Metabolic",
      "url": "/#series-2",
      "description": "Browse the Metabolic Masters series",
      "icons": [{ "src": "icon-96x96.png", "sizes": "96x96" }]
    },
    {
      "name": "Meditation Music",
      "short_name": "Meditation",
      "url": "/#series-1",
      "description": "Browse the Meditation Music series",
      "icons": [{ "src": "icon-96x96.png", "sizes": "96x96" }]
    }
  ],

  "share_target": {
    "action": "/",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  }
}
