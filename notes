<script>
/* ── Notes App ── */
var NOTES_KEY    = 'pnm_notes';
var EPISODES_KEY = 'pnm_notes_episodes';
var notes        = [];
var currentId    = null;
var saveTimer    = null;
var episodes     = [];

/* ── Storage ── */
function loadNotes() {
  try { notes = JSON.parse(localStorage.getItem(NOTES_KEY) || '[]'); } catch(e) { notes = []; }
}
function saveNotes() {
  try { localStorage.setItem(NOTES_KEY, JSON.stringify(notes)); } catch(e) {}
}
function genId() { return Date.now() + '-' + Math.random().toString(36).slice(2, 8); }

/* ── Episode list (loaded from localStorage set by main app) ── */
function loadEpisodes() {
  try {
    var raw = localStorage.getItem('pnm_notes_episodes');
    if (raw) { episodes = JSON.parse(raw); return; }
  } catch(e) {}
  // Fallback: fetch RSS feed and parse titles
  fetch('https://media.rss.com/sacredherbology/feed.xml')
    .then(function(r) { return r.text(); })
    .then(function(text) {
      var matches = text.match(/<title><!\[CDATA\[([^\]]+)\]\]><\/title>|<title>([^<]+)<\/title>/g) || [];
      episodes = matches.slice(1).map(function(m, i) {
        var title = m.replace(/<\/?title>|<!\[CDATA\[|\]\]>/g, '').trim();
        return { num: matches.length - 1 - i, title: title };
      });
      populateEpisodeSelect();
    }).catch(function() {});
}

function populateEpisodeSelect() {
  var sel = document.getElementById('note-episode-select');
  sel.innerHTML = '<option value="">— Not linked to an episode —</option>';
  episodes.forEach(function(ep) {
    var opt = document.createElement('option');
    opt.value = ep.num;
    opt.textContent = 'Ep ' + ep.num + ' — ' + ep.title.substring(0, 50);
    sel.appendChild(opt);
  });
  // Set current value
  if (currentId) {
    var note = notes.find(function(n) { return n.id === currentId; });
    if (note) sel.value = note.episodeNum || '';
  }
}

/* ── Render notes list ── */
function renderNotesList(filter) {
  var list = document.getElementById('notes-list');
  var filtered = filter
    ? notes.filter(function(n) {
        var q = filter.toLowerCase();
        return (n.title + ' ' + n.body + ' ' + (n.episodeTitle || '')).toLowerCase().includes(q);
      })
    : notes.slice();
  // Sort by updatedAt descending
  filtered.sort(function(a, b) { return (b.updatedAt || 0) - (a.updatedAt || 0); });
  if (!filtered.length) {
    list.innerHTML = '<div class="notes-empty">No notes yet.<br>Create your first one!</div>';
    return;
  }
  list.innerHTML = filtered.map(function(n) {
    var preview = (n.body || '').replace(/\n/g, ' ').substring(0, 60);
    var date    = n.updatedAt ? new Date(n.updatedAt).toLocaleDateString('en-AU', { day: 'numeric', month: 'short', year: 'numeric' }) : '';
    var epLabel = n.episodeTitle ? 'Ep ' + n.episodeNum + ' — ' + n.episodeTitle.substring(0, 30) : 'Unlinked';
    return '<div class="note-item' + (n.id === currentId ? ' active' : '') + '" data-id="' + n.id + '">' +
      '<div class="note-item-episode">' + epLabel + '</div>' +
      '<div class="note-item-title">' + (n.title || 'Untitled note') + '</div>' +
      '<div class="note-item-preview">' + (preview || 'No content yet') + '</div>' +
      '<div class="note-item-date">' + date + '</div>' +
    '</div>';
  }).join('');
  list.querySelectorAll('.note-item').forEach(function(el) {
    el.addEventListener('click', function() { openNote(el.getAttribute('data-id')); });
  });
}

/* ── Open a note ── */
function openNote(id) {
  var note = notes.find(function(n) { return n.id === id; });
  if (!note) return;
  currentId = id;
  document.getElementById('notes-welcome').style.display = 'none';
  var editorActive = document.getElementById('editor-active');
  editorActive.style.display = 'flex';
  document.getElementById('note-title').value = note.title || '';
  document.getElementById('note-body').value  = note.body  || '';
  document.getElementById('note-episode-select').value = note.episodeNum || '';
  document.getElementById('header-sub').textContent = note.episodeTitle || 'The Precision Health Podcast';
  renderNotesList(document.getElementById('notes-search').value);
  // Close mobile sidebar
  document.getElementById('notes-sidebar').classList.remove('open');
}

/* ── Create new note ── */
function createNote(episodeNum, episodeTitle) {
  var note = {
    id:           genId(),
    title:        episodeTitle ? 'Notes — ' + episodeTitle.substring(0, 40) : '',
    body:         '',
    episodeNum:   episodeNum   || '',
    episodeTitle: episodeTitle || '',
    createdAt:    Date.now(),
    updatedAt:    Date.now()
  };
  notes.unshift(note);
  saveNotes();
  renderNotesList();
  openNote(note.id);
  setTimeout(function() {
    var titleInput = document.getElementById('note-title');
    titleInput.focus(); titleInput.select();
  }, 50);
}

/* ── Auto-save ── */
function scheduleSave() {
  clearTimeout(saveTimer);
  document.getElementById('save-indicator').textContent = 'Saving...';
  document.getElementById('save-indicator').className = 'save-indicator';
  saveTimer = setTimeout(function() { saveCurrentNote(); }, 600);
}
function saveCurrentNote() {
  if (!currentId) return;
  var note = notes.find(function(n) { return n.id === currentId; });
  if (!note) return;
  note.title        = document.getElementById('note-title').value.trim();
  note.body         = document.getElementById('note-body').value;
  var sel           = document.getElementById('note-episode-select');
  note.episodeNum   = sel.value;
  note.episodeTitle = sel.options[sel.selectedIndex] ? sel.options[sel.selectedIndex].textContent.replace(/^Ep \d+ — /, '') : '';
  note.updatedAt    = Date.now();
  saveNotes();
  renderNotesList(document.getElementById('notes-search').value);
  document.getElementById('header-sub').textContent = note.episodeTitle || 'The Precision Health Podcast';
  var ind = document.getElementById('save-indicator');
  ind.textContent = 'All changes saved'; ind.className = 'save-indicator saved';
}

/* ── Delete ── */
function deleteCurrentNote() {
  if (!currentId) return;
  if (!confirm('Delete this note? This cannot be undone.')) return;
  notes = notes.filter(function(n) { return n.id !== currentId; });
  saveNotes();
  currentId = null;
  document.getElementById('editor-active').style.display = 'none';
  document.getElementById('notes-welcome').style.display = 'flex';
  renderNotesList();
}

/* ── Format helpers ── */
function formatText(type) {
  var ta  = document.getElementById('note-body');
  var s   = ta.selectionStart;
  var e   = ta.selectionEnd;
  var val = ta.value;
  var sel = val.slice(s, e);
  var insert = '';
  if (type === 'bold')     insert = '**' + (sel || 'bold text') + '**';
  if (type === 'italic')   insert = '_' + (sel || 'italic text') + '_';
  if (type === 'heading')  insert = '\n## ' + (sel || 'Heading') + '\n';
  if (type === 'bullet')   insert = '\n• ' + (sel || 'Item');
  if (type === 'numbered') insert = '\n1. ' + (sel || 'Item');
  if (type === 'timestamp') {
    // Try to get current playback time from main app localStorage
    var resume = null;
    try { resume = JSON.parse(localStorage.getItem('pnm_podcast_resume') || 'null'); } catch(ex) {}
    var ts = resume ? '[' + formatTime(resume.time) + ']' : '[' + new Date().toLocaleTimeString() + ']';
    insert = ts + ' ';
  }
  ta.value = val.slice(0, s) + insert + val.slice(e);
  ta.selectionStart = ta.selectionEnd = s + insert.length;
  ta.focus();
  scheduleSave();
}
function formatTime(s) {
  s = Math.floor(s || 0);
  var m = Math.floor(s / 60); s = s % 60;
  return (m < 10 ? '0' : '') + m + ':' + (s < 10 ? '0' : '') + s;
}

/* ── Export ── */
function exportNote() {
  if (!currentId) return;
  var note = notes.find(function(n) { return n.id === currentId; });
  if (!note) return;
  var content = (note.title ? '# ' + note.title + '\n\n' : '') +
    (note.episodeTitle ? 'Episode: ' + note.episodeTitle + '\n\n' : '') +
    (note.body || '') + '\n\n---\nThe Precision Health Podcast — precisionnaturalemedicine.com.au';
  var blob = new Blob([content], { type: 'text/plain' });
  var a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = (note.title || 'note').replace(/[^a-z0-9 ]/gi, '').trim() + '.txt';
  document.body.appendChild(a); a.click(); document.body.removeChild(a);
}

/* ── Init ── */
document.addEventListener('DOMContentLoaded', function() {
  loadNotes();
  loadEpisodes();
  renderNotesList();

  document.getElementById('new-note-btn').addEventListener('click', function() { createNote(); });
  document.getElementById('welcome-new-btn').addEventListener('click', function() { createNote(); });
  document.getElementById('sidebar-toggle').addEventListener('click', function() {
    document.getElementById('notes-sidebar').classList.toggle('open');
  });
  document.getElementById('notes-search').addEventListener('input', function() {
    renderNotesList(this.value);
  });
  document.getElementById('note-title').addEventListener('input', scheduleSave);
  document.getElementById('note-body').addEventListener('input', scheduleSave);
  document.getElementById('note-episode-select').addEventListener('change', scheduleSave);

  // Check if opened from note_taking new_note_url or with a ?episode= param
  var params = new URLSearchParams(window.location.search);
  var epNum  = params.get('episode');
  var epTitle = params.get('title');
  var newNote = params.get('new');
  if (newNote || epNum) {
    createNote(epNum || '', epTitle || '');
  } else if (notes.length > 0) {
    // Auto-open most recent note
    var sorted = notes.slice().sort(function(a,b) { return (b.updatedAt||0) - (a.updatedAt||0); });
    openNote(sorted[0].id);
  }
});

// Register SW
if ('serviceWorker' in navigator) {
  navigator.serviceWorker.register('/sw.js').catch(function(){});
}

// Expose episode list for the main app to call
window.setEpisodesForNotes = function(epList) {
  episodes = epList;
  try { localStorage.setItem('pnm_notes_episodes', JSON.stringify(epList)); } catch(e) {}
  populateEpisodeSelect();
};
</script>
<!-- Floating action button — always visible on mobile -->
<button id="fab-new-note" aria-label="New note" title="New note" style="
  position: fixed; bottom: 24px; right: 24px; z-index: 200;
  width: 52px; height: 52px; border-radius: 50%;
  background: var(--green-deep); color: var(--white);
  border: none; cursor: pointer; box-shadow: 0 4px 16px rgba(44,74,53,0.4);
  display: flex; align-items: center; justify-content: center;
  font-size: 28px; font-weight: 300; line-height: 1;
  transition: background 0.2s, transform 0.15s;
  -webkit-tap-highlight-color: transparent;">+</button>

<script>
document.getElementById('fab-new-note').addEventListener('click', function() {
  createNote();
});
document.getElementById('fab-new-note').addEventListener('mouseenter', function() {
  this.style.transform = 'scale(1.1)';
});
document.getElementById('fab-new-note').addEventListener('mouseleave', function() {
  this.style.transform = 'scale(1)';
});
</script>
</body>
