        Create Your First Note
      </button>
    </div>

    <div id="editor-active" style="display:none;flex:1;flex-direction:column;overflow:hidden;">
      <div class="notes-editor-toolbar">
        <button onclick="formatText('bold')"><strong>B</strong></button>
        <button onclick="formatText('italic')"><em>I</em></button>
        <button onclick="formatText('heading')">H</button>
        <button onclick="formatText('bullet')">&#8226; List</button>
        <button onclick="formatText('numbered')">1. List</button>
        <div class="toolbar-sep"></div>
        <button onclick="formatText('timestamp')" title="Insert current playback time">&#9201; Timestamp</button>
